# Runtime-окружение контейнера `web` (docker compose).
# Отличие от .env: хосты указывают на сервисы compose, а не на localhost.
# PG_USER / PG_PASSWORD / PG_DATABASE / GO_PORT должны совпадать со значениями в .env
# (их docker compose подставляет в db/migration/caddy).

#####          POSTGRES ENV'S          #####
PG_USER=        # тот же, что в .env
PG_PASSWORD=    # тот же, что в .env
PG_HOST=db      # имя сервиса postgres в docker-compose.yml
PG_PORT=5432    # внутренний порт postgres в сети compose
PG_DATABASE=    # тот же, что в .env
PG_SSL_MODE=disable

#####          REDIS ENV'S             #####

REDIS_HOST=redis  # имя сервиса redis в docker-compose.yml
REDIS_PORT=6379   # внутренний порт redis в сети compose

#####          JWT ENV'S               #####

JWT_SECRET=     # Secret for generating JWT

#####          GO BACKEND ENV'S        #####

GO_PORT=        # тот же, что в .env (его expose'ит web и проксирует caddy)
CORS_ALLOWED_ORIGINS=*
APP_ENV=production
GLOBAL_RATE_LIMIT=   # Global Rate Limit
GLOBAL_RATE_BURST=   # Global Rate Burst
IP_RATE_LIMIT=       # IP Rate Limit
IP_RATE_BURST=       # Ip Rate Burst

#####          LECHESS API ENV'S        #####

LICHESS_GET_GAMES_URL=https://lichess.org/api/games/user/
